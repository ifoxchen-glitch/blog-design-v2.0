</nav>
<form method="post" action="/admin/logout" class="admin-inline">
<button class="admin-btn admin-btn--ghost" type="submit">&#36864;&#20986;</button>
</form>
</div>
</header>

<main class="site-main">
<header class="admin-header">
<h1 class="page-title">API&#23545;&#25509;&#31649;&#29702;</h1>
</header>

<article class="admin-card">
<h2 class="admin-card__title">API&#23494;&#38144;</h2>
<div class="admin-form">
<label class="admin-label">
&#24403;&#21069;API&#23494;&#38144;
<input class="admin-input" value="<%= agentApiKey || '' %>" readonly />
</label>
</div>
</article>

<article class="admin-card">
<h2 class="admin-card__title">&#21516;&#27493;Obsidian&#30693;&#35782;&#24211;</h2>
<div class="admin-form">
<label class="admin-label admin-label--full">
Vault&#36335;&#24452;
<input class="admin-input" id="vaultPath" placeholder="&#30041;&#31354;&#20351;&#29992;&#40664;&#35748;&#36335;&#24452;" />
</label>
<label class="admin-label admin-label--full">
Slug&#21069;&#32512;
<input class="admin-input" id="slugPrefix" value="obsidian-" />
</label>
<button class="admin-btn" onclick="syncObsidian()">&#24320;&#22987;&#21516;&#27493;</button>
<pre id="syncResult" class="admin-result"></pre>
</div>
</article>

<article class="admin-card">
<h2 class="admin-card__title">API&#27979;&#35797;</h2>
<div class="admin-form">
<label class="admin-label admin-label--full">
&#27979;&#31456;&#26631;&#39064;
<input class="admin-input" id="testTitle" placeholder="&#25991;&#31456;&#26631;&#39064;" />
</label>
<label class="admin-label admin-label--full">
&#20869;&#23481;
<textarea class="admin-textarea" id="testContent" rows="5" placeholder="Markdown&#20869;&#23481;"></textarea>
</label>
<button class="admin-btn" onclick="testPublish()">&#27979;&#31456;&#21457;&#24067;</button>
<pre id="testResult" class="admin-result"></pre>
</div>
</article>

<article class="admin-card">
<h2 class="admin-card__title">API&#25991;&#26723;</h2>
<pre class="api-docs">## Agent API

### &#35748;&#35777;
Header: X-API-Key: your-key

### 1. &#21457;&#24067;&#25991;&#31456;
POST /api/agent/publish
&#21442;&#25991;: title, contentMarkdown, status

### 2. &#21516;&#27493;&#20998;&#31867;
POST /api/agent/sync-categories
&#21442;&#25991;: categories: ["&#25216;&#26415>["Tech","Life"]

### 3. &#21516;&#27493;&#26631;&#31614;
POST /api/agent/sync-tags
&#21442;&#25991;: tags: ["&#21069;&#31454>["Frontend","Backend"]

### 4. &#21516;&#27493;Obsidian
POST /api/agent/sync-obsidian
&#21442;&#25991;: vaultPath, slugPrefix

## Obsidian Frontmatter
---
title: My Post
tags: test
status: published
---
</pre>
</article>
</main>

<script>
function syncObsidian() {
var vaultPath = document.getElementById('vaultPath').value || null;
var slugPrefix = document.getElementById('slugPrefix').value || 'obsidian-';
var result = document.getElementById('syncResult');
result.textContent = '&#21516;&#27493;&#20013;...';
fetch('/api/agent/sync-obsidian', {
method: 'POST',
headers: {'Content-Type': 'application/json'},
body: JSON.stringify({vaultPath: vaultPath, slugPrefix: slugPrefix})
}).then(function(r){return r.json();}).then(function(data){
result.textContent = JSON.stringify(data, null, 2);
}).catch(function(e){
result.textContent = '&#38169;&#35823;: ' + e.message;
});
}

function testPublish() {
var title = document.getElementById('testTitle').value;
var content = document.getElementById('testContent').value;
var result = document.getElementById('testResult');
if(!title) {alert('&#35831;&#36755;&#20837;&#26631;&#39064;'); return;}
result.textContent = '&#21457;&#24067;&#20013;...';
fetch('/api/agent/publish', {
method: 'POST',
headers: {'Content-Type': 'application/json'},
body: JSON.stringify({title: title, contentMarkdown: content || '# ' + title, status: 'draft'})
}).then(function(r){return r.json();}).then(function(data){
result.textContent = JSON.stringify(data, null, 2);
}).catch(function(e){
result.textContent = '&#38169;&#35823;: ' + e.message;
});
}
</script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Posts - Admin</title>
<link rel="stylesheet" href="/css/tokens.css" />
<link rel="stylesheet" href="/css/base.css" />
<link rel="stylesheet" href="/css/components.css" />
<link rel="stylesheet" href="/admin-static/admin.css" />
</head>
<body>
<header class="site-header">
<div class="site-header__inner">
<a class="site-logo" href="/">ifoxchen's blog</a>
<nav class="nav-desktop" aria-label="Admin Nav">
<a href="/admin/posts" aria-current="page">Posts</a>
<a href="/admin/links">Links</a>
<a href="/admin/api">API</a>
</nav>
<form method="post" action="/admin/logout" class="admin-inline">
<button class="admin-btn admin-btn--ghost" type="submit">Logout</button>
</form>
</div>
</header>

<main class="site-main">
<header class="admin-header">
<h1 class="page-title">Posts</h1>
<a class="admin-btn" href="/admin/posts/new">New Post</a>
</header>

<form class="admin-search" method="get" action="/admin/posts">
<input class="admin-input" type="text" name="q" placeholder="Search posts..." value="<%= typeof q !== 'undefined' ? q : '' %>" />
<button class="admin-btn" type="submit">Search</button>
<% if (typeof q !== 'undefined' && q) { %>
<a class="admin-btn admin-btn--ghost" href="/admin/posts">Clear</a>
<% } %>
</form>

<div class="admin-table">
<div class="admin-table__head">
<div>Title</div>
<div>Status</div>
<div>Updated</div>
<div>Actions</div>
</div>
<% posts.forEach(function(p){ %>
<div class="admin-table__row">
<div><a href="/admin/posts/<%= p.id %>/edit"><%= p.title %></a></div>
<div><%= p.status === "published" ? "Published" : "Draft" %></div>
<div><%= new Date(p.updatedAt).toLocaleDateString() %></div>
<div>
<a href="/admin/posts/<%= p.id %>/edit">Edit</a>
</div>
</div>
<% }); %>
</div>
</main>
</body>
</html>
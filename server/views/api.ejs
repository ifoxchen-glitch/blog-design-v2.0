<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>API Settings - Admin</title>
<link rel="stylesheet" href="/css/tokens.css" />
<link rel="stylesheet" href="/css/base.css" />
<link rel="stylesheet" href="/css/components.css" />
<link rel="stylesheet" href="/admin-static/admin.css" />
</head>
<body>
<header class="site-header">
<div class="site-header__inner">
<a class="site-logo" href="/">ifoxchen's blog</a>
<nav class="nav-desktop" aria-label="Admin Nav">
<a href="/admin/posts">Posts</a>
<a href="/admin/links">Links</a>
<a href="/admin/api" aria-current="page">API</a>
</nav>
<form method="post" action="/admin/logout" class="admin-inline">
<button class="admin-btn admin-btn--ghost" type="submit">Logout</button>
</form>
</div>
</header>
</header>

<main class="site-main">
<header class="admin-header">
<h1 class="page-title">API Settings</h1>
</header>

<article class="admin-card">
<h2 class="admin-card__title">API Key</h2>
<div class="admin-form">
<label class="admin-label">
Current API Key
<input class="admin-input" value="<%= agentApiKey || '' %>" readonly />
</label>
</div>
</article>

<article class="admin-card">
<h2 class="admin-card__title">Sync Obsidian Vault</h2>
<div class="admin-form">
<label class="admin-label admin-label--full">
Vault Path (leave empty for default)
<input class="admin-input" id="vaultPath" placeholder="~/obsidian" />
</label>
<label class="admin-label admin-label--full">
Slug Prefix
<input class="admin-input" id="slugPrefix" value="obsidian-" />
</label>
<button class="admin-btn" onclick="syncObsidian()">Start Sync</button>
<pre id="syncResult" class="admin-result"></pre>
</div>
</article>

<article class="admin-card">
<h2 class="admin-card__title">Test API</h2>
<div class="admin-form">
<label class="admin-label admin-label--full">
Article Title
<input class="admin-input" id="testTitle" placeholder="Title" />
</label>
<label class="admin-label admin-label--full">
Content (Markdown)
<textarea class="admin-textarea" id="testContent" rows="5" placeholder="Markdown content"></textarea>
</label>
<button class="admin-btn" onclick="testPublish()">Publish Test</button>
<pre id="testResult" class="admin-result"></pre>
</div>
</article>

<article class="admin-card">
<h2 class="admin-card__title">API Documentation</h2>
<pre class="api-docs">## Agent API Endpoints

=== Authentication ===
Header: X-API-Key: your-api-key

=== 1. Publish Post ===
POST /api/agent/publish
Params:
  - title: string (required)
  - contentMarkdown: string
  - status: "published" or "draft"
  - tags: comma-separated
  - categories: comma-separated

=== 2. Sync Categories ===
POST /api/agent/sync-categories
Body: {"categories":["Tech","Life"]}

=== 3. Sync Tags ===
POST /api/agent/sync-tags
Body: {"tags":["Frontend","Backend"]}

=== 4. Sync Obsidian ===
POST /api/agent/sync-obsidian
Body: {"vaultPath":"/path/to/vault","slugPrefix":"obsidian-"}

=== Obsidian Frontmatter ===
---
title: My Post
tags: test,api
categories: Tech
excerpt: Summary
cover: /path/to/image.jpg
status: published
---
</pre>
</article>
</main>

<script>
function syncObsidian() {
var vp = document.getElementById('vaultPath').value || null;
var sp = document.getElementById('slugPrefix').value || 'obsidian-';
var r = document.getElementById('syncResult');
r.textContent = 'Syncing...';
fetch('/api/agent/sync-obsidian', {
method: 'POST',
headers: {'Content-Type': 'application/json'},
body: JSON.stringify({vaultPath: vp, slugPrefix: sp})
}).then(function(x){return x.json();}).then(function(d){
r.textContent = JSON.stringify(d, null, 2);
}).catch(function(e){
r.textContent = 'Error: ' + e.message;
});
}

function testPublish() {
var t = document.getElementById('testTitle').value;
var c = document.getElementById('testContent').value;
var r = document.getElementById('testResult');
if(!t) {alert('Please enter title'); return;}
r.textContent = 'Publishing...';
fetch('/api/agent/publish', {
method: 'POST',
headers: {'Content-Type': 'application/json'},
body: JSON.stringify({title: t, contentMarkdown: c || '# ' + t, status: 'draft'})
}).then(function(x){return x.json();}).then(function(d){
r.textContent = JSON.stringify(d, null, 2);
}).catch(function(e){
r.textContent = 'Error: ' + e.message;
});
}
</script>
</body>
</html>
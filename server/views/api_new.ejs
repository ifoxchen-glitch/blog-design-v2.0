<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>API对接 · 博客后台</title>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/admin-static/admin.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-logo" href="/">ifoxchen's blog</a>
        <nav class="nav-desktop" aria-label="后台导航">
          <a href="/admin/posts">文章</a>
          <a href="/admin/links">站外链接</a>
          <a href="/admin/api" aria-current="page">API对接</a>
          <a href="/index.html">前台</a>
        </nav>
        <form method="post" action="/admin/logout" class="admin-inline">
          <button class="admin-btn admin-btn--ghost" type="submit">退出</button>
        </form>
      </div>
    </header>

    <main class="site-main">
      <header class="admin-header">
        <h1 class="page-title">API对接管理</h1>
      </header>

      <article class="admin-card">
        <h2 class="admin-card__title">API密钥</h2>
        <div class="admin-form">
          <div class="admin-grid">
            <div>
              <p class="admin-label">当前API密钥</p>
              <code class="api-key-display" id="apiKey"><%= agentApiKey || '未设置' %></code>
            </div>
            <div>
              <p class="admin-label">操作</p>
              <button class="admin-btn" onclick="regenerateKey()">重新生成密钥</button>
            </div>
          </div>
        </div>
      </article>

      <article class="admin-card">
        <h2 class="admin-card__title">同步Obsidian知识库</h2>
        <div class="admin-form">
          <label class="admin-label admin-label--full">
            Vault路径
            <input class="admin-input" id="vaultPath" placeholder="留空使用默认路径: ~/obsidian" />
          </label>
          <label class="admin-label admin-label--full">
            Slug前缀
            <input class="admin-input" id="slugPrefix" placeholder="obsidian-" value="obsidian-" />
          </label>
          <button class="admin-btn" onclick="syncObsidian()">开始同步</button>
          <div id="syncResult" class="admin-result"></div>
        </div>
      </article>

      <article class="admin-card">
        <h2 class="admin-card__title">API测试</h2>
        <div class="admin-form">
          <div class="admin-grid">
            <div>
              <label class="admin-label">
                测试发布文章
                <input class="admin-input" id="testTitle" placeholder="文章标题" />
              </label>
            </div>
            <div>
              <label class="admin-label">
                内容
                <input class="admin-input" id="testContent" placeholder="Markdown内容" />
              </label>
            </div>
          </div>
          <button class="admin-btn" onclick="testPublish()">测试发布</button>
          <div id="testResult" class="admin-result"></div>
        </div>
      </article>

      <article class="admin-card">
        <h2 class="admin-card__title">API文档</h2>
        <pre class="api-docs">## Agent API 端点

### 认证
所有API请求需要在Header中携带API密钥：
X-API-Key: your-api-key

### 1. 发布文章
POST /api/agent/publish
参数：
  - title: 文章标题
  - slug: URL别名（可选，自动生成）
  - excerpt: 摘要（可选）
  - coverImageUrl: 封面图（可选）
  - contentMarkdown: Markdown内容
  - tags: 标签，逗号分隔（可选）
  - categories: 分类，逗号分隔（可选）
  - status: published/draft（默认draft）

### 2. 同步分类
POST /api/agent/sync-categories
参数：
  - categories: JSON数组，如["技术","生活"]

### 3. 同步标签
POST /api/agent/sync-tags
参数：
  - tags: JSON数组，如["前端","后端"]

### 4. 同步Obsidian
POST /api/agent/sync-obsidian
参数：
  - vaultPath: Obsidian库路径（可选）
  - slugPrefix: 文章slug前缀（可选，默认"obsidian-"）

### Obsidian Frontmatter 支持
```yaml
---
title: 文章标题
slug: url-slug
tags: 前端,JavaScript
categories: 技术
excerpt: 摘要
cover: /path/to/cover.jpg
status: published
---
```
        </pre>
      </article>
    </main>

    <script>
      async function apiRequest(url, data) {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data)
        });
        return response.json();
      }

      async function regenerateKey() {
        if (!confirm('确定要重新生成API密钥吗？')) return;
        const result = await apiRequest('/admin/api/regenerate-key', {});
        document.getElementById('apiKey').textContent = result.apiKey || '未设置';
        alert('密钥已重新生成！');
      }

      async function syncObsidian() {
        const vaultPath = document.getElementById('vaultPath').value || null;
        const slugPrefix = document.getElementById('slugPrefix').value || 'obsidian-';
        const resultDiv = document.getElementById('syncResult');
        
        resultDiv.innerHTML = '同步中...';
        
        try {
          const result = await apiRequest('/api/agent/sync-obsidian', {
            vaultPath,
            slugPrefix
          });
          resultDiv.innerHTML = JSON.stringify(result, null, 2);
        } catch (e) {
          resultDiv.innerHTML = '错误: ' + e.message;
        }
      }

      async function testPublish() {
        const title = document.getElementById('testTitle').value;
        const content = document.getElementById('testContent').value;
        const resultDiv = document.getElementById('testResult');
        
        if (!title) {
          alert('请输入文章标题');
          return;
        }
        
        resultDiv.innerHTML = '发布中...';
        
        try {
          const result = await apiRequest('/api/agent/publish', {
            title,
            contentMarkdown: content || '# ' + title,
            status: 'draft'
          });
          resultDiv.innerHTML = JSON.stringify(result, null, 2);
        } catch (e) {
          resultDiv.innerHTML = '错误: ' + e.message;
        }
      }
    </script>
  </body>
</html>

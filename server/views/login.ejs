<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>登录 · 博客后台</title>
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/admin-static/admin.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-logo" href="/">ifoxchen's blog</a>
        <nav class="nav-desktop" aria-label="后台导航">
          <a href="/admin/posts">文章</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <article class="admin-card">
        <h1 class="page-title" style="margin-top: 0">后台登录</h1>
        <% if (typeof error !== "undefined" && error) { %>
          <p class="admin-error"><%= error %></p>
        <% } %>
        <form method="post" action="/admin/login" class="admin-form">
          <label class="admin-label">
            邮箱
            <input class="admin-input" name="email" type="email" autocomplete="username" value="<%= adminEmail %>" required />
          </label>
          <label class="admin-label">
            密码
            <input class="admin-input" name="password" type="password" autocomplete="current-password" required />
          </label>
          <button class="admin-btn" type="submit">登录</button>
          <p class="admin-hint">首版默认账号：<code><%= adminEmail %></code>，密码来自环境变量。</p>
        </form>
      </article>
    </main>
  </body>
</html>


# Server port (default: 8787)
PORT=8787

# Session secret - 必须使用强随机值！
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# Admin credentials (defaults shown)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# Optional: bcrypt hash of admin password (takes precedence over ADMIN_PASSWORD)
# 推荐使用 bcrypt 哈希密码（更安全）；填写后 ADMIN_PASSWORD 会被忽略
# ADMIN_PASSWORD_HASH=$2a$10$...
ADMIN_PASSWORD_HASH=

# Agent API Key（用于外部 Agent 发布文章）
# 生成方法: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AGENT_API_KEY=

# 站点 URL（用于 RSS 等绝对链接）
SITE_URL=https://ifoxchen.com

# ============================================
# Open WebUI 配置
# ============================================
# Open WebUI 内部端口（仅本地，不对外暴露）
OPEN_WEBUI_PORT=8080
OPEN_WEBUI_HOST=127.0.0.1

# 向量数据库类型: chroma | pgvector | milvus | oracle23ai
VECTOR_DB=chroma

# 禁用遥测
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMOUS_TELEMETRY=false
